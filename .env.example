# Meta Conversions API — set these in Vercel Dashboard
# Project → Settings → Environment Variables

# The Meta Pixel / Dataset ID connected to your Events Manager
# Currently in Events Manager: 1690219565624509 (Infinite RoofMaxx dataset)
# Currently in landing page HTML: 1010755291154748
# CONFIRM which ID is correct before setting this var.
META_PIXEL_ID=YOUR_PIXEL_ID_HERE

# Generate from Events Manager → Settings → Conversions API → Generate access token
# Brad must click "Generate access token" button in Events Manager Settings tab.
META_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE
